PORT=3333
NODE_ENV=development

# Firebase Admin
# Local option: save the service account JSON outside Git.
# Windows example:
# FIREBASE_SERVICE_ACCOUNT_PATH=C:/vendaon/backend/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=torico-ca479

# Development-only protection key.
# Never commit the real value.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TORICO_DEV_KEY=

# Development/test-only endpoints.
# Keep false in production.
ENABLE_TEST_ENDPOINTS=false

# Mercado Pago OAuth multi-merchant integration.
# Never commit real values.
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
MERCADO_PAGO_REDIRECT_URI=https://torico-backend-16783123127.us-central1.run.app/integrations/mercado-pago/callback

# Mercado Pago webhook signature secret.
MERCADO_PAGO_WEBHOOK_SECRET=

# Encryption key used to encrypt/decrypt OAuth tokens.
# Must be 64 hexadecimal characters.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Optional legacy/MVP fallback.
# In production multi-merchant, keep ENABLE_MERCADO_PAGO_MVP_FALLBACK=false.
# This fallback exists only for controlled migration/debug scenarios.
ENABLE_MERCADO_PAGO_MVP_FALLBACK=false
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_DEFAULT_USER_ID=

# Public URLs
PUBLIC_BACKEND_URL=https://torico-backend-16783123127.us-central1.run.app
PUBLIC_APP_URL=https://torico-ca479.web.app
