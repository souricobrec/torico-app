PORT=3333

# Opção local recomendada:
# Baixe uma chave de service account no Firebase Console e salve fora do Git.
# Exemplo no Windows:
# FIREBASE_SERVICE_ACCOUNT_PATH=C:/vendaon/backend/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=

# Projeto Firebase do TORICO.
FIREBASE_PROJECT_ID=torico-ca479

# Chave usada somente para proteger endpoints de desenvolvimento.
# Nunca envie a chave real para o GitHub.
# Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TORICO_DEV_KEY=

# Habilita rotas de teste/desenvolvimento.
# Em produção real, mantenha como false.
# Use true apenas em ambiente controlado para criar preferências sandbox/teste.
ENABLE_TEST_ENDPOINTS=false

# Mercado Pago OAuth
# Usado futuramente para conexão multiusuário.
# Nunca enviar valores reais para o GitHub.
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
MERCADO_PAGO_REDIRECT_URI=https://torico-backend-16783123127.us-central1.run.app/integrations/mercado-pago/callback

# Segredo de assinatura dos webhooks do Mercado Pago.
MERCADO_PAGO_WEBHOOK_SECRET=

# Chave local do TORICO para criptografar tokens OAuth antes de salvar.
# Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Precisa ter 64 caracteres hexadecimais.
TOKEN_ENCRYPTION_KEY=

# MVP Mercado Pago sem OAuth multiusuário.
# Access Token fica somente no backend, nunca no Flutter/PWA.
MERCADO_PAGO_ACCESS_TOKEN=

# UID Firebase do usuário TORICO que receberá as vendas do MVP.
MERCADO_PAGO_DEFAULT_USER_ID=

# URLs públicas usadas ao criar preferência de pagamento.
PUBLIC_BACKEND_URL=https://torico-backend-16783123127.us-central1.run.app
PUBLIC_APP_URL=https://torico-ca479.web.app